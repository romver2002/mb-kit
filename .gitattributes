# Канонические переводы строк — LF во всём репозитории.
# Инструменты (bump_frontmatter, mb_log) пишут LF; единый EOL исключает
# ложные срабатывания сравнения тел и порчу файлов на разных ОС.
* text=auto eol=lf

# git-хук должен приходить исполняемым на unix-клоны (см. также
# git update-index --chmod=+x при первом коммите).
scripts/git-hooks/pre-commit text eol=lf
